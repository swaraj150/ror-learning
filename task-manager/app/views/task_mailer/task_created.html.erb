<h2>Hi <%= @user.name %>,</h2>

<p>This is a notification that the following task has been created</p>

<table>
  <tr><td><strong>Title</strong></td><td><%= @task.title %></td></tr>
  <tr><td><strong>Status</strong></td><td><%= @task.status %></td></tr>
  <tr><td><strong>Priority</strong></td><td><%= @task.priority %></td></tr>
  <tr><td><strong>Due Date</strong></td><td><%= @task.due_date.strftime('%B %d, %Y at %I:%M %p') %></td></tr>
</table>

<p>
  <% if @task.description.present? %>
    <%= @task.description %>
  <% end %>
</p>
